                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/accounts/9999999999/deposits", "host": ["{{baseUrl}}"], "path": ["api","v1","accounts","9999999999","deposits"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.00,\n  \"description\": \"Test\",\n  \"reference\": \"DEP-NOTFOUND-001\"\n}"
            }
          }
        }

      ]
    },

    {
      "name": "04 - Retiros",
      "item": [

        {
          "name": "Retiro exitoso (201)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('lastWithdrawRef', 'WD-' + Date.now());"
