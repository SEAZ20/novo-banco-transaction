            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 0.00,\n  \"description\": \"Monto inválido\",\n  \"reference\": \"DEP-ZERO\"\n}"
            }
          }
        },

        {
          "name": "Depósito - cuenta no encontrada (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
