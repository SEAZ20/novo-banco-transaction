                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Tipo DEPOSIT y estado SUCCESS', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.type).to.eql('DEPOSIT');",
                  "    pm.expect(body.status).to.eql('SUCCESS');",
                  "    pm.expect(body.amount).to.eql(1000);",
                  "    pm.expect(body.balanceAfter).to.eql(1000);",
                  "});"
                ]
