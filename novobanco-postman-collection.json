{
  "info": {
    "name": "NovoBanco — Transaction API",
    "_postman_id": "novobanco-transaction-api-v1",
    "description": "Colección completa para validar el microservicio de Gestión de Cuentas y Transacciones.\n\nFlujo recomendado: ejecutar las carpetas en orden (01 → 06). Las requests guardan variables automáticamente (customerId, accountNumber, etc.) para las siguientes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",              "value": "http://localhost:8080" },
    { "key": "customerId",           "value": "" },
    { "key": "customerId2",          "value": "" },
    { "key": "accountNumber",        "value": "" },
    { "key": "secondAccountNumber",  "value": "" },
    { "key": "statusTestAccount",    "value": "" },
    { "key": "lastDepositRef",       "value": "" },
    { "key": "lastWithdrawRef",      "value": "" },
    { "key": "lastTransferRef",      "value": "" }
  ],
  "item": [

    {
      "name": "01 - Clientes",
      "item": [

        {
          "name": "Crear cliente (201)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const ts = Date.now();",
                  "pm.collectionVariables.set('customerEmail',  'cliente' + ts + '@novobanco.com');",
                  "pm.collectionVariables.set('customerDoc',    'DOC' + ts);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Retorna id', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.be.a('number');",
                  "    pm.collectionVariables.set('customerId', body.id);",
                  "});",
                  "pm.test('Retorna email correcto', () => {",
                  "    pm.expect(pm.response.json().email).to.eql(pm.collectionVariables.get('customerEmail'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/customers", "host": ["{{baseUrl}}"], "path": ["api","v1","customers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ana García\",\n  \"email\": \"{{customerEmail}}\",\n  \"documentNumber\": \"{{customerDoc}}\"\n}"
            }
          }
        },

        {
          "name": "Crear segundo cliente (para segunda cuenta)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const ts = Date.now() + 1;",
                  "pm.collectionVariables.set('customerEmail2', 'cliente2' + ts + '@novobanco.com');",
                  "pm.collectionVariables.set('customerDoc2',   'DOC2' + ts);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('customerId2', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/customers", "host": ["{{baseUrl}}"], "path": ["api","v1","customers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Carlos Ruiz\",\n  \"email\": \"{{customerEmail2}}\",\n  \"documentNumber\": \"{{customerDoc2}}\"\n}"
            }
          }
        },

        {
          "name": "Crear cliente - email duplicado (409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));",
                  "pm.test('Contiene tipo de error', () => {",
                  "    pm.expect(pm.response.json().status).to.eql(409);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/customers", "host": ["{{baseUrl}}"], "path": ["api","v1","customers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Otro cliente\",\n  \"email\": \"{{customerEmail}}\",\n  \"documentNumber\": \"DOCUNICO999\"\n}"
            }
          }
        },

        {
          "name": "Crear cliente - email inválido (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 Bad Request', () => pm.response.to.have.status(400));",
                  "pm.test('Contiene detalle de validación', () => {",
                  "    pm.expect(pm.response.json().detail).to.include('email');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/customers", "host": ["{{baseUrl}}"], "path": ["api","v1","customers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test\",\n  \"email\": \"no-es-un-email\",\n  \"documentNumber\": \"DOC123\"\n}"
            }
          }
        },

        {
          "name": "Crear cliente - campos vacíos (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 Bad Request', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/customers", "host": ["{{baseUrl}}"], "path": ["api","v1","customers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"email\": \"\",\n  \"documentNumber\": \"\"\n}"
            }
          }
        }

      ]
    },

    {
      "name": "02 - Cuentas",
      "item": [

        {
          "name": "Crear cuenta SAVINGS (201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Cuenta activa con saldo cero', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.status).to.eql('ACTIVE');",
                  "    pm.expect(body.balance).to.eql(0);",
                  "    pm.expect(body.accountNumber).to.match(/^\\d{10}$/);",
                  "    pm.collectionVariables.set('accountNumber', body.accountNumber);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/accounts", "host": ["{{baseUrl}}"], "path": ["api","v1","accounts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": {{customerId}},\n  \"type\": \"SAVINGS\"\n}"
            }
          }
        },

        {
          "name": "Crear cuenta CHECKING (segunda cuenta)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Tipo CHECKING', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.type).to.eql('CHECKING');",
                  "    pm.collectionVariables.set('secondAccountNumber', body.accountNumber);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/accounts", "host": ["{{baseUrl}}"], "path": ["api","v1","accounts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": {{customerId2}},\n  \"type\": \"CHECKING\"\n}"
            }
          }
        },

        {
          "name": "Obtener cuenta por número (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Número de cuenta correcto', () => {",
                  "    pm.expect(pm.response.json().accountNumber).to.eql(pm.collectionVariables.get('accountNumber'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/accounts/{{accountNumber}}", "host": ["{{baseUrl}}"], "path": ["api","v1","accounts","{{accountNumber}}"] }
          }
        },

        {
          "name": "Obtener cuenta - no encontrada (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 Not Found', () => pm.response.to.have.status(404));",
                  "pm.test('Error de cuenta no encontrada', () => {",
                  "    pm.expect(pm.response.json().status).to.eql(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/accounts/9999999999", "host": ["{{baseUrl}}"], "path": ["api","v1","accounts","9999999999"] }
          }
        },

        {
          "name": "Obtener cuentas por cliente (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna lista no vacía', () => {",
                  "    pm.expect(pm.response.json()).to.be.an('array').with.lengthOf.at.least(1);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/accounts/customer/{{customerId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","accounts","customer","{{customerId}}"] }
          }
        },

        {
          "name": "Crear cuenta - cliente no existe (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 Not Found', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/accounts", "host": ["{{baseUrl}}"], "path": ["api","v1","accounts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": 999999,\n  \"type\": \"SAVINGS\"\n}"
            }
          }
        }

      ]
    },

